# ============================================================================
# Study Group Accountability Bot - Example environment configuration
# Copy this file to ".env" and fill in real values before running.
# ============================================================================

# Telegram bot token from @BotFather
BOT_TOKEN=123456789:AAExampleTokenReplaceMe

# Telegram group/chat id where scheduled reports are posted (e.g. -1001234567890)
GROUP_ID=-1001234567890

# SQLAlchemy database URL. SQLite (default) needs no extra server.
#   - SQLite file: sqlite:///data/study_bot.db
#   - Postgres:    postgresql+asyncpg://user:pass@localhost:5432/study_bot
DATABASE_URL=sqlite:///data/study_bot.db

# Daily report time in HH:MM (24h, UTC). Default 02:30 UTC == 08:00 IST
REPORT_TIME=02:30

# Application timezone (IANA name, e.g. UTC, Asia/Kolkata, America/New_York)
TIMEZONE=UTC

# Comma/semicolon separated list of Telegram user ids allowed to use /admin*
ADMIN_IDS=111111111,222222222

# Group average hours below which /focuscheck sends a motivational nudge
FOCUS_THRESHOLD=2.0

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# ----------------------------------------------------------------------------
# Optional tuning (sane defaults are used if omitted)
# ----------------------------------------------------------------------------
# Maximum hours that may be logged in a single day per user
MAX_HOURS_PER_DAY=16

# Minutes during which /editlog and /undo remain available
EDIT_WINDOW_MINUTES=10

# Minutes used to detect accidental duplicate submissions
DUPLICATE_WINDOW_MINUTES=2

# XP granted per studied hour
XP_PER_HOUR=10

# Reminder times (UTC) for inactive users, comma separated
REMINDER_TIMES=09:00,14:00,19:00
